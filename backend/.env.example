# ---------------------------------------------------------------------------
# Backend environment template. Copy to `backend/.env` for local development.
# Production values come from deploy/.env (mounted by docker compose).
# All keys MUST be enumerated here so that Settings.model_validate() succeeds.
# ---------------------------------------------------------------------------

# PostgreSQL — must be the asyncpg driver URL.
DATABASE_URL=postgresql+asyncpg://platform:platform@localhost:5432/platform

# Redis 7.x
REDIS_URL=redis://localhost:6379/0

# 32+ char random string — used for JWT signing & general crypto.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-random-48-char-string

# logging
LOG_LEVEL=INFO

# dev | test | prod
ENVIRONMENT=dev

# CORS — comma-separated list (parsed as JSON array if it starts with `[`).
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# Optional — when set, traces/metrics are exported to this OTEL collector.
# Leave blank in dev to disable.
OTEL_ENDPOINT=

# Build metadata — typically injected by CI / docker build args.
# Leave blank locally; the application falls back to `git rev-parse HEAD`.
COMMIT_SHA=

# Spec data root — platform-managed spec storage directory.
# Relative paths resolve against backend/ working directory.
# Default: /data/sillyspec-data (Linux) / C:/data/sillyspec-data (Windows).
SPEC_DATA_ROOT=./data/spec-storage

# ── Object storage (platform file center) ─────────────────────────────
# 存储后端（minio；未来可加 oss 等 S3 兼容实现）。
STORAGE_BACKEND=minio
# S3 兼容端点。本地 dev 用 localhost:9000；Docker 内用 http://minio:9000。
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=platform-files
S3_REGION=us-east-1
# 单文件上传大小上限（MB），超限 413。
FILE_MAX_SIZE_MB=50
# 上传 MIME 白名单（逗号分隔），不在列 415；排除 text/html、image/svg+xml（D-009）。
FILE_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/zip,text/plain
