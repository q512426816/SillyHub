{
  "name": "sillyhub-daemon",
  "version": "0.1.0",
  "description": "SillyHub local daemon for task execution (Node.js rewrite)",
  "private": true,
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "sillyhub-daemon": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "start": "node dist/cli.js",
    "bundle": "bash scripts/build-bundle.sh",
    "gen:types": "node scripts/gen-api-types.mjs",
    "gen:types:check": "node scripts/gen-api-types.mjs && git diff --exit-code src/api-types.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.6.0",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.181",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "overrides": {
      "@anthropic-ai/claude-agent-sdk-win32-x64": "npm:@anthropic-ai/claude-agent-sdk@0.3.181",
      "@anthropic-ai/claude-agent-sdk-win32-arm64": "npm:@anthropic-ai/claude-agent-sdk@0.3.181",
      "@anthropic-ai/claude-agent-sdk-linux-x64": "npm:@anthropic-ai/claude-agent-sdk@0.3.181",
      "@anthropic-ai/claude-agent-sdk-linux-arm64": "npm:@anthropic-ai/claude-agent-sdk@0.3.181",
      "@anthropic-ai/claude-agent-sdk-linux-x64-musl": "npm:@anthropic-ai/claude-agent-sdk@0.3.181",
      "@anthropic-ai/claude-agent-sdk-linux-arm64-musl": "npm:@anthropic-ai/claude-agent-sdk@0.3.181",
      "@anthropic-ai/claude-agent-sdk-darwin-x64": "npm:@anthropic-ai/claude-agent-sdk@0.3.181",
      "@anthropic-ai/claude-agent-sdk-darwin-arm64": "npm:@anthropic-ai/claude-agent-sdk@0.3.181"
    }
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "20.14.0",
    "@types/ws": "^8.5.12",
    "@vercel/ncc": "^0.44.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "5.5.4",
    "vitest": "^2.0.0"
  }
}
