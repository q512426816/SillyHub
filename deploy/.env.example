# ---------------------------------------------------------------------------
# Compose-level environment template. Copy to deploy/.env when running locally.
# Values here are forwarded into the backend / frontend containers; do NOT
# commit a populated .env (gitignored).
# ---------------------------------------------------------------------------

# Postgres
POSTGRES_DB=platform
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend
BACKEND_PORT=8000
SECRET_KEY=change-me-to-a-random-48-char-string
LOG_LEVEL=INFO
ENVIRONMENT=dev
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
OTEL_ENDPOINT=
COMMIT_SHA=

# Agent CLI versions baked into the backend image
CLAUDE_CODE_VERSION=2.1.158
SILLYSPEC_VERSION=3.16.2

# Claude Code runtime settings for the backend container
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
API_TIMEOUT_MS=3000000
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
ANTHROPIC_DEFAULT_HAIKU_MODEL=GLM-4.5-air
ANTHROPIC_DEFAULT_SONNET_MODEL=GLM-4.5-air
ANTHROPIC_DEFAULT_OPUS_MODEL=GLM-4.5-air
ANTHROPIC_AUTH_TOKEN=
CLAUDE_CODE_MODEL=opus[1m]
CLAUDE_PLUGIN_FRONTEND_DESIGN_ENABLED=true
CLAUDE_PLUGIN_PLAYWRIGHT_ENABLED=true
CLAUDE_SYNC_OFFICIAL_PLUGINS_ON_START=true
CLAUDE_SKIP_DANGEROUS_MODE_PERMISSION_PROMPT=true

# Auth bootstrap (task-04a)
# If set, backend will create/reuse this admin on startup.
PLATFORM_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
PLATFORM_BOOTSTRAP_ADMIN_PASSWORD=Admin123!@#
PLATFORM_BOOTSTRAP_ADMIN_DISPLAY_NAME=Admin

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_COMMIT_SHA=
