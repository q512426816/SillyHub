# ---------------------------------------------------------------------------
# Compose-level environment template. Copy to deploy/.env when running locally.
# Values here are forwarded into the backend / frontend containers; do NOT
# commit a populated .env (gitignored).
# ---------------------------------------------------------------------------

# Postgres
POSTGRES_DB=platform
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend
BACKEND_PORT=8000
SECRET_KEY=change-me-to-a-random-48-char-string
LOG_LEVEL=INFO
ENVIRONMENT=dev
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
OTEL_ENDPOINT=
COMMIT_SHA=

# Auth bootstrap (task-04a)
# If set, backend will create/reuse this admin on startup.
PLATFORM_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
PLATFORM_BOOTSTRAP_ADMIN_PASSWORD=Admin123!@#
PLATFORM_BOOTSTRAP_ADMIN_DISPLAY_NAME=Admin

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_COMMIT_SHA=
